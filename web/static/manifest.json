{
    "name": "InfoKeep",
    "short_name": "InfoKeep",
    "description": "Your personal information manager for bookmarks, notes, recipes and more",
    "start_url": "/",
    "display": "standalone",
    "background_color": "#312E81",
    "theme_color": "#312E81",
    "orientation": "portrait-primary",
    "icons": [
        {
            "src": "/static/icons/icon-192.svg",
            "sizes": "192x192",
            "type": "image/svg+xml",
            "purpose": "any"
        },
        {
            "src": "/static/icons/icon-512.svg",
            "sizes": "512x512",
            "type": "image/svg+xml",
            "purpose": "any"
        }
    ],
    "share_target": {
        "action": "/share",
        "method": "GET",
        "params": {
            "title": "title",
            "text": "text",
            "url": "url"
        }
    }
}